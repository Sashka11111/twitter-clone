<!DOCTYPE html>
<html class="scroll-smooth">
  <head>
    <title>Twitter Clone | Premium</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    darkMode: 'media'
  }
</script>
    <%= stylesheet_link_tag "application" %>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      body { font-family: 'Outfit', sans-serif !important; }
    </style>
  </head>

  <body>
    <nav class="glass-nav sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center space-x-3 no-underline group" do %>
          <div class="w-10 h-10 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200 dark:shadow-none group-hover:rotate-12 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="text-2xl font-black tracking-tighter text-slate-900 dark:text-white">TWITTER <span class="text-indigo-600">CLONE</span></span>
        <% end %>

        <div class="flex items-center space-x-8">
          <% if logged_in? %>
            <%= link_to user_path(current_user), class: "flex items-center space-x-3 text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-indigo-400 transition no-underline" do %>
              <div class="w-10 h-10 rounded-[14px] bg-slate-100 dark:bg-slate-800 p-0.5 border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm flex items-center justify-center">
                <% if current_user.avatar_url.present? %>
                  <img src="<%= current_user.avatar_url %>" class="w-full h-full object-cover rounded-[12px]">
                <% else %>
                  <div class="w-full h-full flex items-center justify-center text-indigo-500 font-bold text-sm bg-indigo-100 dark:bg-indigo-900/40 rounded-[12px]">
                    <%= current_user.username[0].upcase %>
                  </div>
                <% end %>
              </div>
              <span class="font-bold hidden md:inline text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400">@<%= current_user.username %></span>
            <% end %>
            <%= button_to logout_path, method: :delete, class: "btn-secondary !py-2 !px-4 !text-sm cursor-pointer" do %>
              Вихід
            <% end %>
          <% else %>
            <%= link_to "Вхід", login_path, class: "text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 font-bold transition no-underline" %>
            <%= link_to signup_path, class: "btn-premium" do %>
              Приєднатися
            <% end %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-10">
      <% flash.each do |type, msg| %>
        <div class="mb-8 p-5 rounded-3xl border <%= type == 'notice' ? 'bg-emerald-50 border-emerald-100 text-emerald-700 dark:bg-emerald-900/20 dark:border-emerald-900/50 dark:text-emerald-400' : 'bg-rose-50 border-rose-100 text-rose-700 dark:bg-rose-900/20 dark:border-rose-900/50 dark:text-rose-400' %> flex items-center justify-between animate-entrance shadow-sm">
          <p class="font-bold m-0"><%= msg %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="py-12 border-t border-slate-100 dark:border-slate-900 text-center">
      <p class="text-slate-400 dark:text-slate-600 text-sm font-medium">© 2026 Twitter Clone Premium. Всі права захищено.</p>
    </footer>
  </body>
</html>

