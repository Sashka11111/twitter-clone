<div class="container max-w-2xl">
  <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 overflow-hidden shadow-sm mb-8 animate-in">
    <div class="banner"></div>
    <div class="px-6 pb-6">
      <div class="flex justify-between items-end -mt-16 mb-6">
        <div class="profile-avatar-wrap">
          <% if @user.avatar_url.present? %>
            <img src="<%= @user.avatar_url %>" class="profile-avatar">
          <% else %>
            <div class="profile-avatar flex items-center justify-center text-indigo-500 font-bold text-4xl bg-indigo-100 dark:bg-indigo-900/40">
              <%= @user.username[0].upcase %>
            </div>
          <% end %>
        </div>
        
        <div class="mb-2">
          <% if logged_in? && current_user != @user %>
            <% if current_user.following?(@user) %>
              <%= button_to "Відписатися", follow_path(@user), method: :delete, class: "btn-secondary cursor-pointer" %>
            <% else %>
              <%= button_to "Підписатися", follows_path(followed_id: @user.id), class: "btn-primary cursor-pointer" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="profile-info">
        <h1 class="profile-name text-slate-900 dark:text-white">@<%= @user.username %></h1>
        <p class="profile-handle text-slate-500 dark:text-slate-400"><%= @user.email %></p>
        
        <% if @user.bio.present? %>
          <div class="mt-4 text-slate-800 dark:text-slate-200 leading-relaxed text-lg">
            <%= @user.bio %>
          </div>
        <% else %>
          <p class="text-slate-400 dark:text-slate-500 italic mt-4">Жодної інформації про себе...</p>
        <% end %>

        <div class="mt-6 flex space-x-6 border-t border-slate-100 dark:border-slate-800 pt-6">
          <div class="flex space-x-1 items-center">
            <span class="font-bold text-slate-900 dark:text-white"><%= @user.following.count %></span>
            <span class="text-slate-500 dark:text-slate-400 text-sm">Підписок</span>
          </div>
          <div class="flex space-x-1 items-center">
            <span class="font-bold text-slate-900 dark:text-white"><%= @user.followers.count %></span>
            <span class="text-slate-500 dark:text-slate-400 text-sm">Підписників</span>
          </div>
          <div class="flex space-x-1 items-center">
            <span class="font-bold text-slate-900 dark:text-white"><%= @user.posts.count %></span>
            <span class="text-slate-500 dark:text-slate-400 text-sm">Постів</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 overflow-hidden shadow-sm">
    <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800">
      <h2 class="text-lg font-bold m-0 text-slate-900 dark:text-white">Пости користувача</h2>
    </div>
    <div class="divide-y divide-slate-100 dark:divide-slate-800">
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="p-6 hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition animate-in">
            <div class="flex gap-4">
              <% if post.user.avatar_url.present? %>
                <img src="<%= post.user.avatar_url %>" class="w-12 h-12 rounded-2xl flex-shrink-0 object-cover shadow-sm">
              <% else %>
                <div class="w-12 h-12 rounded-2xl flex-shrink-0 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-500 font-bold flex items-center justify-center text-lg shadow-sm">
                  <%= post.user.username[0].upcase %>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center space-x-1 mb-1">
                  <span class="font-bold text-slate-900 dark:text-white">@<%= post.user.username %></span>
                  <span class="text-slate-500 dark:text-slate-400 text-sm">· <%= time_ago_in_words(post.created_at) %></span>
                </div>
                <div class="text-[16px] text-slate-800 dark:text-slate-200 leading-normal">
                  <%= post.content %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="p-16 text-center text-slate-400 dark:text-slate-500">
          <p class="text-lg">У цього користувача ще немає постів.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex justify-center pb-12">
    <%= paginate @posts %>
  </div>
</div>
