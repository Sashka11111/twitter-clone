<div class="container-premium">
  <div class="grid grid-cols-12 gap-6 lg:gap-8">
    <!-- Left Sidebar: Navigation -->
    <div class="hidden lg:block lg:col-span-3">
      <div class="sticky top-24 space-y-3">
        <%= link_to root_path, class: "flex items-center space-x-4 p-4 rounded-2xl hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-s font-bold transition group no-underline text-slate-900 dark:text-slate-100" do %>
          <div class="p-2 rounded-xl bg-indigo-500 text-white shadow-lg shadow-indigo-200 dark:shadow-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <span class="group-hover:text-indigo-600 transition-colors">Головна</span>
        <% end %>
        
        <% if logged_in? %>
          <%= link_to user_path(current_user), class: "flex items-center space-x-4 p-4 rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-800 text-s font-bold transition no-underline text-slate-700 dark:text-slate-300" do %>
            <div class="p-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <span>Профіль</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Main Feed -->
    <div class="col-span-12 lg:col-span-6 feed-column bg-white dark:bg-slate-950/40">
      <div class="p-5 border-b border-slate-100 dark:border-slate-800 sticky top-16 glass-nav z-40">
        <h1 class="text-2xl font-black m-0 tracking-tight text-slate-900 dark:text-white">Для вас</h1>
      </div>

      <% if logged_in? %>
        <div class="p-6 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/20">
          <div class="flex space-x-4">
            <div class="w-14 h-14 rounded-2xl bg-indigo-100 dark:bg-indigo-900/40 overflow-hidden flex-shrink-0 shadow-sm">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" class="w-full h-full object-cover">
              <% else %>
                 <div class="w-full h-full flex items-center justify-center text-indigo-500 font-bold text-xl">
                   <%= current_user.username[0].upcase %>
                 </div>
              <% end %>
            </div>
            <div class="flex-1">
              <%= form_with model: @post, local: true, class: "space-y-4" do |f| %>
                <%= f.text_area :content, placeholder: "Що нового?", class: "w-full bg-transparent border-0 focus:ring-0 text-xl resize-none py-2 placeholder:text-slate-400 dark:placeholder:text-slate-600 outline-none dark:text-white", rows: 2 %>
                <div class="flex items-center justify-between pt-4 border-t border-slate-100 dark:border-slate-800">
                  <%= f.submit "Опублікувати", class: "btn-premium px-8 py-2.5 text-base" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <div class="divide-y divide-slate-100 dark:divide-slate-800">
        <% if @posts.any? %>
          <% @posts.each_with_index do |post, index| %>
            <div class="post-wrapper animate-entrance" style="animation-delay: <%= index * 0.1 %>s">
              <div class="flex space-x-4">
                <%= link_to user_path(post.user), class: "flex-shrink-0 no-underline" do %>
                  <% if post.user.avatar_url.present? %>
                    <img src="<%= post.user.avatar_url %>" class="post-avatar">
                  <% else %>
                    <div class="post-avatar flex items-center justify-center text-indigo-500 font-bold text-lg bg-indigo-100 dark:bg-indigo-900/40">
                      <%= post.user.username[0].upcase %>
                    </div>
                  <% end %>
                <% end %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between">
                    <div class="post-header-info">
                      <%= link_to post.user.username, user_path(post.user), class: "post-name hover:underline no-underline" %>
                      <span class="post-handle">@<%= post.user.username %> · <%= time_ago_in_words(post.created_at) %></span>
                    </div>
                    <% if post.user == current_user %>
                      <%= button_to post_path(post), method: :delete, class: "icon-action text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 border-none bg-transparent cursor-pointer", data: { turbo_confirm: "Ви впевнені?" } do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                  <div class="post-text dark:text-slate-200">
                    <%= post.content %>
                  </div>

                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-20 text-center">
            <div class="w-20 h-20 bg-slate-50 dark:bg-slate-900 rounded-3xl flex items-center justify-center mx-auto mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <p class="text-2xl font-bold mb-2 text-slate-900 dark:text-white">Ваша стрічка порожня</p>
            <p class="text-slate-500 dark:text-slate-400">Підпишіться на когось, щоб бачити пости тут.</p>
          </div>
        <% end %>
      </div>

      <div class="py-12 flex justify-center">
        <%= paginate @posts %>
      </div>
    </div>

    <!-- Right Sidebar -->
    <div class="hidden lg:block lg:col-span-3">
      <div class="sticky top-24 space-y-6">
        <div class="sidebar-section bg-indigo-50/50 dark:bg-indigo-950/20 border-indigo-100 dark:border-indigo-900/50">
          <h2 class="sidebar-title text-indigo-900 dark:text-indigo-100">Кого читати</h2>
          <div class="space-y-5">
            <% @recommended_users.each do |user| %>
              <div class="flex items-center justify-between group">
                <div class="flex items-center space-x-3 overflow-hidden">
                  <% if user.avatar_url.present? %>
                    <img src="<%= user.avatar_url %>" class="w-11 h-11 rounded-xl flex-shrink-0 shadow-sm group-hover:scale-105 transition-transform object-cover">
                  <% else %>
                    <div class="w-11 h-11 rounded-xl flex-shrink-0 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-500 font-bold flex items-center justify-center text-sm shadow-sm group-hover:scale-105 transition-transform">
                      <%= user.username[0].upcase %>
                    </div>
                  <% end %>
                  <div class="truncate">
                    <p class="font-bold text-sm truncate m-0 text-slate-900 dark:text-white"><%= link_to user.username, user_path(user), class: "no-underline hover:underline" %></p>
                    <p class="text-xs text-slate-500 truncate m-0">@<%= user.username %></p>
                  </div>
                </div>
                <% if logged_in? %>
                  <%= button_to "Читати", follows_path(followed_id: user.id), class: "bg-white dark:bg-slate-800 text-slate-900 dark:text-white font-bold py-2 px-4 rounded-xl text-xs shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition border-none cursor-pointer" %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

